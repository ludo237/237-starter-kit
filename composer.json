{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "ludo237/237-starter-kit",
    "type": "project",
    "description": "Opinionated Laravel starter kit with React, Inertia and Tailwindcss.",
    "keywords": [
        "laravel",
        "framework",
        "react",
        "inertia",
        "starter kit"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/fortify": "^1.30",
        "laravel/framework": "^13.0",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/wayfinder": "^0.1.9"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2.0",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.7",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.18",
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan wayfinder:generate --with-form --path=resources/js/wayfinder"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan wayfinder:generate --with-form --path=resources/js/wayfinder",
            "@php artisan boost:update"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('./envs/.env.dev', '.env');\""
        ],
        "post-create-project-cmd": [
            "make laravel-init"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
